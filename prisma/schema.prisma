// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?
  role          String    @default("ADMIN") // ADMIN, RECEPTIONIST
  staffGymId    String?   // for RECEPTIONIST: which gym they belong to
  emailVerified DateTime?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  gym       Gym?
  accounts  Account[]
  sessions  Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Gym {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  address     String?
  phone       String?
  email       String?
  website     String?
  timezone    String   @default("UTC")
  currency    String   @default("USD")
  pricingDaily     Float    @default(5)
  pricingMonthly   Float    @default(49)
  pricingQuarterly Float    @default(120)
  pricingAnnual    Float    @default(399)
  plan        String   @default("STARTER") // STARTER, PROFESSIONAL, ENTERPRISE
  planStatus  String   @default("ACTIVE")  // ACTIVE, PAST_DUE, CANCELED
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId  String @unique
  owner    User   @relation(fields: [ownerId], references: [id])

  members    Member[]
  trainers   Trainer[]
  classes    GymClass[]
  payments   Payment[]
  equipment  Equipment[]
  announcements Announcement[]
  leads      Lead[]
  staff      Staff[]
  payrollRuns PayrollRun[]
  branches   Branch[]
  inventory  InventoryItem[]
  storeSales StoreSale[]
  workoutPlans WorkoutPlan[]
}

model Member {
  id          String   @id @default(cuid())
  gymId       String
  firstName   String
  lastName    String
  email       String
  phone       String?
  address     String?
  dateOfBirth String?
  photo       String?
  membershipType String  @default("MONTHLY") // MONTHLY, QUARTERLY, ANNUAL, DAILY
  membershipStatus String @default("ACTIVE") // ACTIVE, EXPIRED, FROZEN, CANCELED
  startDate   DateTime @default(now())
  endDate     DateTime?
  emergencyContact String?
  emergencyPhone   String?
  healthConditions String?
  goals       String?
  notes       String?
  branchId         String?
  freezeStartedAt  DateTime?
  freezeWeeks      Int?      @default(0)
  totalFreezeWeeks Int?      @default(0)
  stripeCustomerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym          Gym           @relation(fields: [gymId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  payments     Payment[]
  classBookings ClassBooking[]
  checkIns     CheckIn[]
  progress     MemberProgress[]
  workoutPlans WorkoutPlan[]

  @@unique([gymId, email])
}

model Trainer {
  id          String   @id @default(cuid())
  gymId       String
  firstName   String
  lastName    String
  email       String
  phone       String?
  photo       String?
  specialties String?  // JSON array
  bio         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym     Gym        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  classes GymClass[]

  @@unique([gymId, email])
}

model GymClass {
  id          String   @id @default(cuid())
  gymId       String
  trainerId   String?
  name        String
  description String?
  category    String?  // YOGA, HIIT, PILATES, SPINNING, etc.
  duration    Int      // minutes
  capacity    Int      @default(20)
  location    String?
  color       String?  @default("#b5ff47")
  isRecurring Boolean  @default(false)
  recurrenceRule String? // RRULE string
  startTime   DateTime
  endTime     DateTime
  branchId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym      Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  branch   Branch?        @relation(fields: [branchId], references: [id])
  trainer  Trainer?       @relation(fields: [trainerId], references: [id])
  bookings ClassBooking[]
}

model ClassBooking {
  id        String   @id @default(cuid())
  classId   String
  memberId  String
  status    String   @default("CONFIRMED") // CONFIRMED, WAITLIST, CANCELED, ATTENDED
  bookedAt  DateTime @default(now())

  class  GymClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  member Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([classId, memberId])
}

model Payment {
  id          String   @id @default(cuid())
  gymId       String
  memberId    String?
  amount      Float
  currency    String   @default("USD")
  type        String   // MEMBERSHIP, CLASS, PERSONAL_TRAINING, PRODUCT
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  method      String?  // CARD, CASH, BANK_TRANSFER
  description String?
  branchId      String?
  stripePaymentIntentId String?
  stripeInvoiceId String?
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym    Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])
}

model CheckIn {
  id        String   @id @default(cuid())
  memberId  String
  checkedIn DateTime @default(now())
  method    String   @default("MANUAL") // MANUAL, QR, RFID, FACE

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Equipment {
  id           String   @id @default(cuid())
  gymId        String
  name         String
  category     String?  // CARDIO, STRENGTH, FREE_WEIGHTS, etc.
  brand        String?
  serialNumber String?
  purchaseDate DateTime?
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  status       String   @default("OPERATIONAL") // OPERATIONAL, MAINTENANCE, OUT_OF_SERVICE
  branchId     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gym    Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  branch Branch?  @relation(fields: [branchId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  gymId     String
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

// ─── FEATURE 1: Lead & Sales CRM ───────────────────────────────────────────

model Lead {
  id          String   @id @default(cuid())
  gymId       String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  source      String   @default("WALK_IN") // WALK_IN, INSTAGRAM, WHATSAPP, WEBSITE, REFERRAL, OTHER
  status      String   @default("NEW")     // NEW, CONTACTED, TRIAL, NEGOTIATING, CONVERTED, LOST
  assignedTo  String?  // staff name
  notes       String?
  trialStart  DateTime?
  trialEnd    DateTime?
  followUpAt  DateTime?
  convertedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym          Gym           @relation(fields: [gymId], references: [id], onDelete: Cascade)
  interactions LeadInteraction[]
}

model LeadInteraction {
  id        String   @id @default(cuid())
  leadId    String
  type      String   // CALL, MESSAGE, EMAIL, VISIT, NOTE
  note      String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// ─── FEATURE 2: Staff & Payroll ───────────────────────────────────────────

model Staff {
  id         String   @id @default(cuid())
  gymId      String
  firstName  String
  lastName   String
  email      String
  phone      String?
  role       String   @default("STAFF") // STAFF, TRAINER, MANAGER
  salary     Float    @default(0)       // base monthly salary
  salaryType String   @default("MONTHLY") // MONTHLY, HOURLY
  isActive   Boolean  @default(true)
  branchId   String?
  joinDate   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  gym         Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  branch      Branch?      @relation(fields: [branchId], references: [id])
  payrollRuns PayrollRun[]

  @@unique([gymId, email])
}

model PayrollRun {
  id          String   @id @default(cuid())
  gymId       String
  staffId     String
  month       Int      // 1-12
  year        Int
  baseSalary  Float
  commission  Float    @default(0)
  bonus       Float    @default(0)
  deductions  Float    @default(0)
  total       Float
  status      String   @default("PENDING") // PENDING, PAID
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  gym   Gym   @relation(fields: [gymId], references: [id], onDelete: Cascade)
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, month, year])
}

// ─── FEATURE 3: Branch Management ─────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  gymId     String
  name      String
  address   String?
  phone     String?
  email     String?
  manager   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym       Gym        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  members   Member[]
  classes   GymClass[]
  payments  Payment[]
  equipment Equipment[]
  staff     Staff[]
}

// ─── FEATURE 4: Inventory & Store ─────────────────────────────────────────

model InventoryItem {
  id           String   @id @default(cuid())
  gymId        String
  name         String
  sku          String?
  category     String   @default("SUPPLEMENT") // SUPPLEMENT, DRINK, MERCHANDISE, EQUIPMENT, OTHER
  costPrice    Float    @default(0)
  sellPrice    Float    @default(0)
  stock        Int      @default(0)
  lowStockAt   Int      @default(5)  // alert threshold
  barcode      String?
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gym   Gym        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  sales StoreSale[]
}

model StoreSale {
  id        String   @id @default(cuid())
  gymId     String
  itemId    String
  memberId  String?
  quantity  Int      @default(1)
  unitPrice Float
  total     Float
  method    String   @default("CASH") // CASH, CARD
  soldAt    DateTime @default(now())

  gym    Gym           @relation(fields: [gymId], references: [id], onDelete: Cascade)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// ─── FEATURE 5: Member Progress & Workout Plans ───────────────────────────

model MemberProgress {
  id          String   @id @default(cuid())
  memberId    String
  weight      Float?
  bodyFat     Float?
  chest       Float?
  waist       Float?
  hips        Float?
  arms        Float?
  notes       String?
  recordedAt  DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model RateLimitAttempt {
  id          String   @id @default(cuid())
  key         String   @unique
  count       Int      @default(1)
  windowStart DateTime @default(now())
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  gymId       String
  memberId    String
  trainerId   String?
  title       String
  description String?
  goal        String?  // WEIGHT_LOSS, MUSCLE_GAIN, ENDURANCE, FLEXIBILITY
  weeks       Int      @default(4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym      Gym           @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member   Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  exercises PlanExercise[]
}

model PlanExercise {
  id         String @id @default(cuid())
  planId     String
  name       String
  sets       Int    @default(3)
  reps       String @default("10-12")
  rest       Int    @default(60) // seconds
  day        Int    @default(1)  // day of week 1-7
  notes      String?

  plan WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

